{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dacon236694/coordination/usage_ledger.schema.json",
  "title": "usage ledger line v3 (2026-07-14 재설계). ledger/usage.jsonl의 한 줄 = 실제 Codex 호출 1건 또는 cache_hit 1건. ★알 수 없는 토큰은 추정하지 말고 null. 이 스키마는 JSONL 한 줄(객체)에 적용된다.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event",
    "request_id",
    "audit_key",
    "model",
    "reasoning",
    "started_at",
    "ended_at",
    "cache_hit",
    "exit_code",
    "tokens",
    "attempt"
  ],
  "properties": {
    "schema_version": { "const": "3" },
    "event": {
      "type": "string",
      "enum": ["codex_call", "cache_hit"],
      "description": "codex_call = 실제 subprocess 기동. cache_hit = 동일 audit_key 재사용(호출 아님)."
    },
    "request_id": { "type": "string" },
    "audit_key": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "reasoning": { "type": ["string", "null"] },
    "started_at": { "type": ["string", "null"] },
    "ended_at": { "type": ["string", "null"] },
    "cache_hit": { "type": "boolean" },
    "exit_code": { "type": ["integer", "null"] },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output", "total"],
      "description": "CLI가 제공한 token usage. 미제공 = null(추정 금지).",
      "properties": {
        "input": { "type": ["integer", "null"] },
        "output": { "type": ["integer", "null"] },
        "total": { "type": ["integer", "null"] }
      }
    },
    "attempt": { "type": ["integer", "null"] },
    "error_kind": { "type": ["string", "null"] }
  }
}
