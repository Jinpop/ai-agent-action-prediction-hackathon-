{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dacon236694/coordination/audit_result.codex.schema.json",
  "title": "Codex structured-output용 결과 스키마 (07-14 분리·strict 호환: root/전 객체 additionalProperties:false, required=전 키, artifact_sha=배열)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "objective",
    "verdict",
    "auditor_model",
    "completed_at",
    "blocking_findings",
    "nonblocking_findings",
    "verified_claims",
    "unverified_claims",
    "confounders",
    "required_fixes",
    "safe_next_action",
    "evidence_references",
    "artifact_sha"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "BLOCK",
        "NEEDS_HUMAN"
      ]
    },
    "auditor_model": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "nonblocking_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "verified_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unverified_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confounders": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_fixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safe_next_action": {
      "type": "string"
    },
    "evidence_references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_sha": {
      "type": "array",
      "description": "감사 시점 관련 코드·데이터 SHA256 목록 (strict 모드는 동적 키 객체 미지원 → 배열)",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    }
  }
}